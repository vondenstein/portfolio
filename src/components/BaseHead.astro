---
import { siteConfig } from "../config"
import { buildBreadcrumbList } from "../utils/structured-data"

interface Props {
  title?: string
  description?: string
  imgType?: string
  image?: string
  imgTitle?: string
  imgSubtitle?: string
  ogType?: string
  articleDate?: Date
}

const {
  title,
  description,
  imgType,
  image,
  imgTitle,
  imgSubtitle,
  ogType = "website",
  articleDate,
} = Astro.props

const seo = {
  title: title ? `${title} · ${siteConfig.title}` : siteConfig.title,
  description: description ?? siteConfig.description,
}

let ogImage: string | undefined
if (siteConfig.ogImageUrl) {
  const imageUrl = new URL(siteConfig.ogImageUrl)
  imageUrl.searchParams.append("title", imgTitle ?? title ?? siteConfig.title)
  imageUrl.searchParams.append("subtitle", imgSubtitle ?? seo.description)
  if (imgType) imageUrl.searchParams.append("type", imgType)
  if (image) imageUrl.searchParams.append("image", image)
  ogImage = imageUrl.toString()
}

const canonicalUrl = new URL(Astro.url.pathname, siteConfig.siteUrl)
  .toString()
  .replace(/\/$/, "")

const breadcrumbs = buildBreadcrumbList(Astro.url.pathname, siteConfig.siteUrl, title)
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />

<title>{seo.title}</title>
<meta name="description" content={seo.description} />
<link rel="canonical" href={canonicalUrl} />

<link rel="manifest" href="/manifest.webmanifest" />
<link rel="icon" type="image/png" sizes="32x32" href="/icons/icon-32x32.png" />
<link rel="apple-touch-icon" href="/icons/icon-192x192.png" />
<meta name="theme-color" content="#111111" />

<!-- Font preloads -->
<link rel="preload" href="/fonts/rosario.woff2" as="font" type="font/woff2" crossorigin />
<link rel="preload" href="/fonts/crimson-text-400.woff2" as="font" type="font/woff2" crossorigin />
<link rel="preload" href="/fonts/crimson-text-400i.woff2" as="font" type="font/woff2" crossorigin />
<link rel="preload" href="/fonts/crimson-text-600.woff2" as="font" type="font/woff2" crossorigin />

<!-- Open Graph -->
<meta property="og:url" content={canonicalUrl} />
<meta property="og:type" content={ogType} />
<meta property="og:title" content={seo.title} />
<meta property="og:description" content={seo.description} />
{ogImage && <meta property="og:image" content={ogImage} />}
{ogType === "article" && (
  <>
    <meta property="article:author" content={siteConfig.author.name} />
    {articleDate && <meta property="article:published_time" content={articleDate.toISOString()} />}
  </>
)}

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={seo.title} />
<meta name="twitter:description" content={seo.description} />
{siteConfig.twitterHandle && <meta name="twitter:creator" content={siteConfig.twitterHandle} />}
{ogImage && (
  <>
    <meta name="image" content={ogImage} />
    <meta name="twitter:image" content={ogImage} />
  </>
)}

<!-- Structured Data -->
{breadcrumbs && (
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbs)} />
)}
