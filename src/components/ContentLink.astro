---
import { Image } from "astro:assets"
import type { ImageMetadata } from "astro"
import ContentMetadata from "./ContentMetadata.astro"

interface Props {
  title: string
  description?: string | null
  date: string
  readingTime?: number | null
  image: ImageMetadata
  imageAlt?: string
  link: string
  linkTitle?: string
  direction?: "horizontal" | "vertical"
}

const {
  title,
  description,
  date,
  readingTime,
  image,
  imageAlt,
  link,
  linkTitle,
  direction = "horizontal",
} = Astro.props
---

<a href={link} class="link" title={linkTitle}>
  <div class={direction === "horizontal" ? "horizontal-container" : "vertical-container"}>
    <div class="image-wrapper">
      <Image src={image} alt={imageAlt ?? ""} class="image" loading="eager" widths={[400, 800]} sizes="(max-width: 768px) 100vw, 400px" />
    </div>
    <div class={direction === "horizontal" ? "horizontal-text" : "vertical-text"}>
      <h2 class="title">{title}</h2>
      {description && <p class="excerpt">{description}</p>}
      <ContentMetadata date={date} readingTime={readingTime} dark />
    </div>
  </div>
</a>

<style>
  .link {
    text-decoration: none;
  }

  .link div div h2 {
    transition: opacity 0.3s cubic-bezier(0.3, 0.46, 0.45, 0.9);
  }

  .link:hover div div h2 {
    opacity: 0.6;
  }

  .link:hover {
    opacity: 1;
  }

  .horizontal-container {
    display: flex;
    justify-content: space-between;
    flex-direction: row;
    gap: 3rem;
  }

  .vertical-container {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .image-wrapper {
    min-width: 0;
  }

  .image {
    display: block;
    max-width: 100%;
    height: 10rem;
    border-radius: 20px;
    object-fit: cover;
    margin-bottom: 0;
  }

  .horizontal-text {
    flex-shrink: 0;
    margin: auto 0;
    width: 27rem;
  }

  .vertical-text {
    width: 100%;
  }

  .title {
    margin-bottom: 0.5rem;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }

  .excerpt {
    font-weight: 400;
    margin-bottom: 0.5rem;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }

  @media (max-width: 1024px) {
    .horizontal-container {
      gap: 1.5rem;
    }

    .horizontal-text {
      width: 18rem;
    }
  }

  @media (max-width: 768px) {
    .horizontal-container,
    .vertical-container {
      flex-direction: column;
      gap: 1rem;
    }

    .image {
      width: 100%;
    }

    .horizontal-text,
    .vertical-text {
      box-sizing: border-box;
      margin: 0;
      width: 100%;
    }
  }

  @media (max-width: 520px) {
    .horizontal-container,
    .vertical-container {
      background-color: #1b1b1b;
      border-radius: 20px;
      overflow: hidden;
      gap: 0;
    }

    .image {
      border-radius: 0px;
      border-top-left-radius: 20px;
      border-top-right-radius: 20px;
    }

    .horizontal-text,
    .vertical-text {
      padding: 1rem;
    }
  }
</style>
