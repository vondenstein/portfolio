---
import { isBright } from "../utils/is-bright"
import Block from "./Block.astro"
import Button from "./Button.astro"
import type { GitHubRepo } from "../data/github"

interface Props {
  repositories: GitHubRepo[]
}

const { repositories } = Astro.props
---

<div>
  <div class="card-container">
    {repositories.map(repo => {
      const background = repo.primaryLanguage?.color ?? "#fdf9f2"
      const textColor = isBright(background) ? "#3f3f3f" : "#fdf9f2"
      const badgeBg = isBright(background)
        ? "rgba(63, 63, 63, 0.1)"
        : "rgba(253, 249, 242, 0.3)"

      return (
        <a href={repo.url} title={`${repo.name} on GitHub`} class="card">
          <div class="content-container" style={`background-color: ${background}`}>
            <div class="content">
              <div class="top">
                <h3 style={`color: ${textColor}`}>{repo.name}</h3>
                <div class="badge" style={`color: ${textColor}; background-color: ${badgeBg}`}>
                  {repo.isArchived ? (
                    <>Archive</>
                  ) : (
                    <>
                      <img
                        src={isBright(background) ? "/icons/star-dark.svg" : "/icons/star.svg"}
                        alt="Star"
                        class="icon"
                      />{repo.stargazerCount}
                    </>
                  )}
                </div>
              </div>
              <p class="description" style={`color: ${textColor}`}>
                {repo.description}
              </p>
            </div>
          </div>
        </a>
      )
    })}
  </div>

  <Block>
    <h2>Want to see more?</h2>
    <p class="block-text">
      Most of my projects are available for viewing on GitHub. If you'd like
      to see all of my projects - some of which are not listed here - head
      over to GitHub to check them out!{" "}
    </p>
    <Button to="https://github.com/vondenstein" title="Vondenstein on GitHub">
      GitHub
    </Button>
  </Block>
</div>

<style>
  .card-container {
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 2rem;
    margin-bottom: 2rem;
  }

  .card {
    text-decoration: none;
    flex-grow: 1;
    flex-basis: 12rem;
    border-radius: 20px;
    overflow: hidden;
  }

  .card:first-child {
    flex-grow: 2;
    flex-basis: 50%;
  }

  .card:nth-child(2) {
    flex-basis: 18rem;
    flex-shrink: 0;
  }

  .card:hover {
    opacity: 1;
  }

  .card:hover .content {
    opacity: 0.6;
  }

  .content-container {
    height: 100%;
    width: 100%;
  }

  .content {
    color: #fdf9f2;
    padding: 1.7rem;
    transition: opacity 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .badge {
    font-family: sans-serif;
    background-color: rgba(253, 249, 242, 0.3);
    font-size: 0.75rem;
    height: 1.1rem;
    padding: 3px 9px;
    border-radius: 7px;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .top {
    display: flex;
    justify-content: space-between;
  }

  .icon {
    height: 0.75rem;
    width: 0.75rem;
    margin-right: 12px;
    opacity: 90%;
    margin-bottom: -0.1rem;
  }

  .description {
    font-weight: 400;
    font-size: 18px;
    margin: 0;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }

  .block-text {
    max-width: 500px;
    margin: 0 auto 25px;
  }

  @media (max-width: 1024px) {
    .card {
      flex-shrink: 0;
      flex-basis: 10.6rem;
    }

    .card:nth-child(2) {
      flex-basis: 11rem;
    }

    .description {
      overflow: hidden;
      display: -webkit-box;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
    }

    .content {
      padding: 1.6rem;
    }
  }

  @media (max-width: 768px) {
    .card-container {
      flex-direction: column;
      margin-bottom: 2rem;
      gap: 1.5rem;
    }

    .card {
      flex-basis: auto !important;
      margin: 0 !important;
      width: 100% !important;
      display: block !important;
    }

    .content {
      padding: 1.4rem;
    }
  }

  @media (max-width: 520px) {
    .content {
      padding: 1.2rem;
    }
  }
</style>
