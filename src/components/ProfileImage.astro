---
import { Image } from "astro:assets"
import profileImage from "../images/profile.jpg"
---

<Image
  class="image"
  src={profileImage}
  alt="My profile photo."
  loading="eager"
  height={180}
  width={180}
  densities={[1, 2]}
/>

<style>
  .image {
    border-radius: 50%;
    border: 2px solid #434343;
    box-shadow: 0px 15px 30px rgba(0, 0, 0, 0.25);
    margin-bottom: 35px;
  }
</style>
