---
import "../styles/global.css"
import BaseHead from "../components/BaseHead.astro"
import NavDrawer from "../components/NavDrawer.astro"
import NavBar from "../components/NavBar.astro"
import Footer from "../components/Footer.astro"

interface Props {
  title?: string
  description?: string
  imgType?: string
  image?: string
  imgTitle?: string
  imgSubtitle?: string
}

const { title, description, imgType, image, imgTitle, imgSubtitle } =
  Astro.props
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title={title}
      description={description}
      imgType={imgType}
      image={image}
      imgTitle={imgTitle}
      imgSubtitle={imgSubtitle}
    />
  </head>
  <body>
    <NavDrawer />
    <div class="page-container" data-page-container>
      <NavBar />
      <div class="container">
        <main class="main">
          <slot />
        </main>
      </div>
      <Footer />
    </div>
    <script>
      import "../scripts/menu.ts"
    </script>
  </body>
</html>

<style>
  /* PageContainer */

  .page-container {
    background-color: #111111;
    transition: transform 0.7s cubic-bezier(0.55, 0.15, 0.25, 1),
      border-radius 0.7s cubic-bezier(1, 1, 0.67, 1);
    z-index: 2;
    position: relative;
  }

  :global(.menu-open) .page-container {
    transform: translate(0, 24rem);
    transition: transform 0.7s cubic-bezier(0.55, 0.15, 0.25, 1),
      border-radius 0.7s cubic-bezier(0.2, 0, 0, 1);
    border-top-left-radius: 30px;
    border-top-right-radius: 30px;
  }

  @media (max-height: 650px) {
    :global(.menu-open) .page-container {
      transform: translate(0, 18rem);
    }
  }

  /* Layout */

  .container {
    max-width: 1200px;
    margin: 0 auto;
    box-sizing: content-box;
  }

  .main {
    padding: 4rem 0;
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 5rem;
  }

  @media (max-width: 1280px) {
    .container {
      margin: 0 2rem;
    }
  }

  @media (max-width: 1024px) {
    .container {
      max-width: 768px;
      margin: 0 auto;
    }
  }

  @media (max-width: 848px) {
    .container {
      margin: 0 2rem;
    }
  }

  @media (max-width: 768px) {
    .container {
      max-width: 480px;
      margin: 0 auto;
    }

    .main {
      gap: 3rem;
    }
  }

  @media (max-width: 520px) {
    .container {
      padding: 0 1rem;
    }

    .main {
      padding: 2rem 0 1rem;
      gap: 2rem;
    }
  }
</style>
